---
import '../styles/hero.css';
---

<section class="hero" aria-labelledby="hero-heading">
    <div class="hero-badge">AI Content Forensics</div>
    <h1 id="hero-heading">
        <span class="hero-line-1">Analyse suspicious text</span>
        <span class="hero-line-2">with <em>23 detection engines.</em></span>
    </h1>
    <p class="hero-sub">
        Paste a URL or text. Get a detailed forensic report from 23 independent AI detectors
        &mdash; statistical, neural, and linguistic &mdash; all running locally.
    </p>
</section>
